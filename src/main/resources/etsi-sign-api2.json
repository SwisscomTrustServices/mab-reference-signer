{
  "openapi": "3.1.0",
  "info": {
    "title": "ETSI-SIGN API",
    "description": "",
    "version": "1.0",
    "contact": {
      "name": "Swisscom Trust Services",
      "url": "https://trustservices.swisscom.com"
    },
    "license": {
      "name": "Swisscom License",
      "url": "https://trustservices.swisscom.com"
    },
    "termsOfService": "https://www.swisscom.ch/en/residential/legal-information.html"
  },
  "tags": [{ "name": "etsi", "description": "etsi operations" }],
  "externalDocs": {
    "description": "Partner Area",
    "url": "https://trustservices.swisscom.com/en/support/help-center/partner-area"
  },
  "components": {
    "schemas": {
      "EtsiSignRequest": {
        "type": "object",
        "properties": {
          "SAD": { "type": "string", "description": "the access token" },
          "conformanceLevel": {
            "default": "AdES-B-LT",
            "type": "string",
            "enum": ["AdES-B-B", "AdES-B-T", "AdES-B-LT", "AdES-B-LTA"],
            "example": "AdES-B-LT"
          },
          "documentDigests": {
            "type": "object",
            "properties": {
              "hashAlgorithmOID": {
                "type": "string",
                "enum": [
                  "2.16.840.1.101.3.4.2.1",
                  "2.16.840.1.101.3.4.2.2",
                  "2.16.840.1.101.3.4.2.3"
                ],
                "example": "2.16.840.1.101.3.4.2.1"
              },
              "hashes": {
                "type": "array",
                "items": {
                  "type": "string",
                  "description": "hash of the document",
                  "example": "hash"
                },
                "description": "hashes of the documents"
              }
            },
            "required": ["hashAlgorithmOID", "hashes"],
            "description": "Contains the hashes of the documents to be signed and the applied hashing algorithm. These values shall correspond to the values in the SAD."
          },
          "signatureFormat": {
            "type": "string",
            "enum": ["P", "C"],
            "example": "P"
          },
          "credentialID": {
            "type": "string",
            "example": "OnDemand-Advanced4",
            "enum": [
              "OnDemand-Advanced4",
              "OnDemand-Advanced4.1-EU",
              "OnDemand-Qualified4",
              "OnDemand-Qualified4.1-EU"
            ]
          },
          "client_id": { "type": "string" }
        },
        "required": ["documentDigests", "signatureFormat", "credentialID"]
      },
      "EtsiSignResponse": {
        "type": "object",
        "properties": {
          "validationInfo": {
            "type": "object",
            "properties": {
              "ocsp": {
                "type": "array",
                "items": { "type": "string", "example": "MII...AGk=" }
              },
              "crl": {
                "type": "array",
                "items": { "type": "string", "example": "MII...sNrI=" }
              }
            },
            "required": ["ocsp", "crl"]
          },
          "responseID": {
            "type": "string",
            "format": "uuid",
            "example": "00000000-0000-0000-0000-000000000000"
          },
          "SignatureObject": {
            "type": "array",
            "items": { "type": "string", "example": "MII2...23w4=" }
          }
        },
        "required": ["validationInfo", "responseID", "SignatureObject"]
      },
      "EtsiSignErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "enum": [
              "invalid_request",
              "unauthorized_client",
              "access_denied",
              "unsupported_response_type",
              "invalid_scope",
              "server_error",
              "temporarily_unavailable",
              "expired_token",
              "invalid_token"
            ],
            "example": "expired_token"
          },
          "error_description": { "type": "string" },
          "transaction_id": { "type": "string", "example": "YXEH5C" }
        },
        "required": ["error", "transaction_id"]
      }
    }
  },
  "paths": {
    "SAD_AUD_CLAIM_VALUE": {
      "post": {
        "summary": "Sign Doc",
        "description": "THIS API IS PROTECTED BY MTLS, THE CORRESPONDING CERTIFICATE IS PROVIDED BY THE SUPPORT TEAM.<br /><br /> There are two endpoints that provide the signDoc functionality.<br /> The signing application has to dynamically use the url that is defined in the SAD claim AUD.",
        "operationId": "signDoc",
        "tags": ["etsi"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EtsiSignRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EtsiSignResponse" }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EtsiSignErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EtsiSignErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  }
}
